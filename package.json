{
  "name": "xerxes-agents",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Bun-native coding-agent and multi-agent runtime with a React + OpenTUI interface.",
  "license": "Apache-2.0",
  "workspaces": [
    "xerxes"
  ],
  "scripts": {
    "build": "bun run --cwd xerxes build",
    "build:runtime": "bun run --cwd xerxes build:runtime",
    "build:ui": "bun run --cwd xerxes build:ui",
    "check": "bun run repo:check && bun run typecheck",
    "dev": "bun run --cwd xerxes dev",
    "docs:build": "bun run --cwd xerxes docs:build",
    "playground:hard": "bun run --cwd xerxes playground:hard",
    "playground:warmup": "bun run --cwd xerxes playground:warmup",
    "real-use": "bun run --cwd xerxes real-use",
    "repo:check": "bun xerxes/scripts/assertBunOnly.ts",
    "release:check": "bun xerxes/scripts/releasePackage.ts check",
    "release:prepare": "bun xerxes/scripts/releasePackage.ts prepare",
    "release:publish-dry-run": "bun xerxes/scripts/releasePackage.ts publish-dry-run",
    "release:smoke": "bun xerxes/scripts/smokeReleasePackage.ts",
    "smoke": "bun run --cwd xerxes smoke:ui",
    "swarm": "bun run --cwd xerxes swarm",
    "test": "bun run --cwd xerxes test",
    "test:runtime": "bun run --cwd xerxes test:runtime",
    "test:ui": "bun run --cwd xerxes test:ui",
    "typecheck": "bun run --cwd xerxes check",
    "verify": "bun run check && bun run test && bun run build",
    "xerxes": "bun xerxes/src/cli.ts"
  }
}
