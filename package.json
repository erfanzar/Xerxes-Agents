{
  "name": "xerxes-agents",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Bun-native coding-agent and multi-agent runtime with a React + OpenTUI interface.",
  "license": "Apache-2.0",
  "workspaces": [
    "src/typescript"
  ],
  "scripts": {
    "build": "bun run --cwd src/typescript build",
    "build:runtime": "bun run --cwd src/typescript build:runtime",
    "build:ui": "bun run --cwd src/typescript build:ui",
    "check": "bun run repo:check && bun run typecheck",
    "dev": "bun run --cwd src/typescript dev",
    "docs:build": "bun run --cwd src/typescript docs:build",
    "playground:hard": "bun run --cwd src/typescript playground:hard",
    "playground:warmup": "bun run --cwd src/typescript playground:warmup",
    "real-use": "bun run --cwd src/typescript real-use",
    "repo:check": "bun src/typescript/scripts/assertBunOnly.ts",
    "release:check": "bun src/typescript/scripts/releasePackage.ts check",
    "release:prepare": "bun src/typescript/scripts/releasePackage.ts prepare",
    "release:smoke": "bun src/typescript/scripts/smokeReleasePackage.ts",
    "smoke": "bun run --cwd src/typescript smoke:ui",
    "swarm": "bun run --cwd src/typescript swarm",
    "test": "bun run --cwd src/typescript test",
    "test:runtime": "bun run --cwd src/typescript test:runtime",
    "test:ui": "bun run --cwd src/typescript test:ui",
    "typecheck": "bun run --cwd src/typescript check",
    "verify": "bun run check && bun run test && bun run build",
    "xerxes": "bun src/typescript/src/cli.ts"
  }
}
